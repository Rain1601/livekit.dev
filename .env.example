# LiveKit Cloud
LIVEKIT_URL=wss://<project-subdomain>.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Agent dispatch
AGENT_NAME=my-agent

# === Model Provider API Keys ===
# At least one LLM provider is required

# OpenAI (LLM + STT + TTS + Realtime)
OPENAI_API_KEY=

# Anthropic (LLM)
ANTHROPIC_API_KEY=

# Google (LLM + STT + TTS + Gemini Live)
GOOGLE_API_KEY=

# Deepgram (STT)
DEEPGRAM_API_KEY=

# Cartesia (TTS)
CARTESIA_API_KEY=

# ElevenLabs (TTS)
ELEVENLABS_API_KEY=

# DeepSeek (LLM, OpenAI-compatible)
DEEPSEEK_API_KEY=

# Doubao (LLM, OpenAI-compatible)
DOUBAO_API_KEY=

# MiniMax (LLM, OpenAI-compatible)
MINIMAX_API_KEY=

# Qwen via DashScope (LLM, OpenAI-compatible)
DASHSCOPE_API_KEY=
